---
import { useTranslations, type Lang } from '../i18n/translations';

interface Props {
  content: string;
  editorNote?: string;
  variations?: string[];
  tags?: string[];
  lang: Lang;
  index: number;
}

const { content, editorNote, variations, tags, lang, index } = Astro.props;
const t = useTranslations(lang);
const cardId = `card-${index}`;
---

<article class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-sm transition-shadow" data-tags={tags?.join(',') ?? ''}>
  <p class="text-gray-800 text-base leading-relaxed whitespace-pre-line">{content}</p>

  {editorNote && (
    <p class="mt-3 text-sm text-amber-600 bg-amber-50 rounded-lg px-3 py-2">
      {t('editor_note')}: {editorNote}
    </p>
  )}

  {variations && variations.length > 0 && (
    <details class="mt-3">
      <summary class="text-sm text-gray-400 cursor-pointer hover:text-amber-500">{t('variations')} ({variations.length})</summary>
      <ul class="mt-2 space-y-1.5 text-sm text-gray-600">
        {variations.map(v => (
          <li class="pl-3 border-l-2 border-amber-200">{v}</li>
        ))}
      </ul>
    </details>
  )}

  <div class="mt-3 flex items-center justify-between">
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map(tag => (
          <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">{tag}</span>
        ))}
      </div>
    )}
    <button
      class="copy-btn text-xs text-gray-400 hover:text-amber-500 transition-colors ml-auto flex-shrink-0"
      data-content={content}
      data-copy-label={t('share_copy')}
      data-copied-label={t('share_copied')}
    >
      {t('share_copy')}
    </button>
  </div>
</article>
