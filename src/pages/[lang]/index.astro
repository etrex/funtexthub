---
import Layout from '../../layouts/Layout.astro';
import ContentCard from '../../components/ContentCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import { supportedLangs, useTranslations, getI18n, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const topicsDir = join(process.cwd(), 'src/content/topics');
const files = await readdir(topicsDir).catch(() => []);
const topics = (await Promise.all(
  files.filter(f => f.endsWith('.json'))
    .map(async f => JSON.parse(await readFile(join(topicsDir, f), 'utf-8')))
)).sort((a, b) => (b.items?.length ?? 0) - (a.items?.length ?? 0));

const categories = [...new Set(topics.map((t: any) => t.category))];

// Daily picks: pick a few random items from different topics
const dailyPicks: { topic: any; item: any }[] = [];
for (const topic of topics) {
  if (!topic.items?.length) continue;
  const todaySeed = new Date().toISOString().slice(0, 10);
  const hash = todaySeed.split('').reduce((acc: number, c: string) => acc + c.charCodeAt(0), 0);
  const idx = (hash + topics.indexOf(topic)) % topic.items.length;
  dailyPicks.push({ topic, item: topic.items[idx] });
}
---

<Layout title={t('site_name')} description={t('hero_subtitle')} lang={lang} currentPath="/">
  <!-- Hero -->
  <section class="text-center py-10 mb-4">
    <h1 class="text-4xl font-bold text-amber-500 mb-4">FunTextHub</h1>
    <p class="text-lg text-gray-500 max-w-2xl mx-auto">{t('hero_subtitle')}</p>
    <button
      id="random-btn"
      class="mt-6 px-6 py-2.5 bg-amber-500 text-white rounded-full font-medium hover:bg-amber-600 transition-colors"
    >
      {t('random_btn')}
    </button>
  </section>

  <!-- Daily Picks -->
  {dailyPicks.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-bold mb-4 text-gray-800">{t('daily_picks')}</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {dailyPicks.map((pick, i) => {
          const i18nData = getI18n(pick.item.i18n, lang);
          const topicI18n = getI18n(pick.topic.i18n, lang);
          return (
            <a href={`/${lang}/topics/${pick.topic.slug}`} class="block">
              <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:border-amber-300 transition-all">
                <span class="text-xs font-semibold text-amber-500 uppercase tracking-wide">{topicI18n?.title}</span>
                <p class="mt-2 text-gray-800 text-sm leading-relaxed line-clamp-4">{i18nData?.content}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <AdSlot />

  <!-- Category Filter -->
  {categories.length > 1 && (
    <div class="flex flex-wrap gap-2 mb-6">
      <button class="px-3 py-1.5 bg-amber-500 text-white rounded-full text-sm font-medium" data-filter="all">
        {t('all_categories')}
      </button>
      {categories.map(cat => (
        <button class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full text-sm font-medium hover:bg-amber-50 hover:text-amber-500 transition" data-filter={cat}>{cat}</button>
      ))}
    </div>
  )}

  <!-- Topics Grid -->
  <section class="mb-12">
    <h2 class="text-lg font-bold mb-4 text-gray-800">{t('all_topics')}</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" id="topics-grid">
      {topics.map((topic: any) => {
        const i18nData = getI18n(topic.i18n, lang);
        const title = i18nData?.title ?? topic.slug;
        const desc = i18nData?.description ?? '';
        const itemCount = topic.items?.length ?? 0;
        const latestDate = topic.items?.at(-1)?.dateAdded ?? '';
        return (
          <a href={`/${lang}/topics/${topic.slug}`} data-category={topic.category}
             class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md hover:border-amber-300 transition-all block">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-semibold text-amber-500 uppercase tracking-wide">{topic.category}</span>
            </div>
            <h3 class="text-lg font-bold mb-2">{title}</h3>
            <p class="text-sm text-gray-500 mb-3 line-clamp-2">{desc}</p>
            <div class="text-xs text-gray-400">
              {itemCount} {t('items_count')} &middot; {t('last_updated')} {latestDate}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>

<script>
  // Category filter
  const buttons = document.querySelectorAll('[data-filter]');
  const cards = document.querySelectorAll('#topics-grid [data-category]');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      buttons.forEach(b => {
        (b as HTMLElement).className = b === btn
          ? 'px-3 py-1.5 bg-amber-500 text-white rounded-full text-sm font-medium'
          : 'px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full text-sm font-medium hover:bg-amber-50 hover:text-amber-500 transition';
      });
      cards.forEach((card: any) => {
        card.style.display = filter === 'all' || card.getAttribute('data-category') === filter ? '' : 'none';
      });
    });
  });

  // Random button
  const randomBtn = document.getElementById('random-btn');
  const allTopicLinks = document.querySelectorAll('#topics-grid a[href]');
  if (randomBtn && allTopicLinks.length > 0) {
    randomBtn.addEventListener('click', () => {
      const idx = Math.floor(Math.random() * allTopicLinks.length);
      const href = allTopicLinks[idx].getAttribute('href');
      if (href) window.location.href = href;
    });
  }
</script>
